{
  "$schema": "https://claude.local/schemas/plugin.schema.json",
  "name": "mui-expert",
  "version": "2.0.0",
  "description": "Comprehensive Material UI (MUI) expert plugin — 22 skills covering theming, CSS variables, Pigment CSS, components, sx/styled, slots API, MUI X (DataGrid, DatePickers, Charts, TreeView), accessibility, performance, SSR/Next.js, animations, virtualization, forms, white-label/multi-tenant, headless (MUI Base), Joy UI, i18n/RTL, testing, and migration. 11 commands and 7 specialized agents.",
  "author": {
    "name": "Claude Code"
  },
  "license": "MIT",
  "keywords": [
    "mui",
    "material-ui",
    "react",
    "theming",
    "design-system",
    "data-grid",
    "date-picker",
    "charts",
    "tree-view",
    "sx-prop",
    "styled",
    "emotion",
    "pigment-css",
    "css-variables",
    "accessibility",
    "responsive",
    "dark-mode",
    "white-label",
    "multi-tenant",
    "ssr",
    "next-js",
    "slots-api",
    "headless",
    "joy-ui",
    "virtualization",
    "animations",
    "i18n",
    "rtl",
    "testing",
    "performance",
    "migration"
  ],
  "permissions": {
    "requires": [
      "read",
      "write",
      "bash"
    ],
    "optional": [
      "agent",
      "mcp",
      "network"
    ]
  },
  "capabilities": {
    "provides": [
      "mui-theming",
      "mui-css-variables",
      "mui-pigment-css",
      "mui-components",
      "mui-sx-styled",
      "mui-slots-api",
      "mui-data-grid",
      "mui-date-pickers",
      "mui-charts",
      "mui-tree-view",
      "mui-accessibility",
      "mui-performance",
      "mui-ssr-nextjs",
      "mui-animations",
      "mui-virtualization",
      "mui-forms-validation",
      "mui-white-label",
      "mui-base-headless",
      "mui-joy-ui",
      "mui-i18n-rtl",
      "mui-testing",
      "mui-migration",
      "mui-design-system"
    ],
    "requires": []
  },
  "contextEntry": "CONTEXT_SUMMARY.md",
  "context": {
    "entry": "CONTEXT_SUMMARY.md",
    "title": "MUI Expert",
    "summary": "Comprehensive Material UI expert — 22 skills, 11 commands, 7 agents covering theming, CSS vars, Pigment CSS, components, slots API, MUI X, accessibility, SSR, performance, white-label, and more.",
    "tags": [
      "mui",
      "material-ui",
      "react",
      "theming",
      "components",
      "design-system",
      "data-grid",
      "charts",
      "accessibility",
      "performance",
      "ssr"
    ],
    "bootstrapFiles": [
      "CONTEXT_SUMMARY.md"
    ],
    "maxTokens": 700,
    "excludeGlobs": [
      "**/node_modules/**",
      "**/dist/**",
      "**/build/**",
      "**/*.zip"
    ],
    "lazyLoadSections": [
      "CLAUDE.md",
      "skills/*/SKILL.md",
      "commands/*.md"
    ]
  }
}
