{
  "name": "claude-code-templating-plugin",
  "version": "2.0.0",
  "description": "Universal templating and Harness expert plugin for Claude Code - enables fully autonomous project generation, pipeline creation, and deployment automation with database-backed registry",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:mcp:harness": "vitest run --filter mcp-harness",
    "test:db": "vitest run --filter registry-db",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude-code",
    "templating",
    "scaffolding",
    "harness",
    "cookiecutter",
    "copier",
    "mcp",
    "pipelines",
    "devops",
    "code-generation",
    "database",
    "prisma",
    "redis"
  ],
  "author": {
    "name": "Markus Ahling",
    "email": "markus@lobbi.io"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Lobbi-Docs/claude",
    "directory": "plugins/claude-code-templating-plugin"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^6.19.3",
    "@upstash/redis": "^1.37.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^2.1.1",
    "chalk": "^5.6.2",
    "dotenv": "^16.6.1",
    "eventemitter3": "^5.0.4",
    "fast-glob": "^3.3.3",
    "glob": "^10.5.0",
    "handlebars": "^4.7.9",
    "inquirer": "^9.3.8",
    "js-yaml": "^4.1.1",
    "nunjucks": "^3.2.4",
    "semver": "^7.7.4",
    "xml2js": "^0.6.2",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.39",
    "@types/nunjucks": "^3.2.6",
    "@types/semver": "^7.7.1",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^8.57.1",
    "prisma": "^6.19.3",
    "rimraf": "^5.0.10",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  },
  "files": [
    "dist",
    "lib",
    "templates",
    "agents",
    "skills",
    "commands"
  ]
}
