{
  "$schema": "../../../schemas/plugin.schema.json",
  "name": "tauri-desktop-studio",
  "version": "1.1.0",
  "description": "Tauri 2.x desktop + iOS + Android plugin. Rust backend (cpal/ONNX/keyring/tokio-tungstenite), Next.js 15 + React 19 + Zustand 5 + Framer Motion 11 + R3F + Rive frontend, capability ACL, Stronghold vault, OAuth PKCE, real-time audio ML (RNNoise/Silero VAD/ECAPA-TDNN), Deepgram live STT, ComplianceRouter SDK gating, sidecar binaries, advanced staged-rollout updater, multi-window/multi-webview orchestration, .docx ingestion. 5 commands, 14 skills, 3 agents.",
  "author": {
    "name": "Markus Ahling"
  },
  "license": "MIT",
  "keywords": [
    "tauri",
    "tauri-2",
    "desktop",
    "ios",
    "android",
    "rust",
    "nextjs",
    "react",
    "zustand",
    "framer-motion",
    "react-three-fiber",
    "rive",
    "ipc",
    "capabilities",
    "stronghold",
    "keyring",
    "cpal",
    "onnx",
    "ort",
    "rnnoise",
    "silero-vad",
    "ecapa-tdnn",
    "deepgram",
    "tokio-tungstenite",
    "websocket",
    "oauth-pkce",
    "compliance-router",
    "eslint-plugin-local",
    "mammoth",
    "react-virtuoso",
    "sidecar",
    "auto-updater",
    "multi-window",
    "audio-ml"
  ],
  "permissions": {
    "requires": [
      "Read",
      "Write",
      "Edit",
      "Bash",
      "Grep",
      "Glob"
    ],
    "optional": []
  },
  "capabilities": {
    "provides": [
      "tauri-scaffold",
      "tauri-config",
      "tauri-ipc-commands",
      "tauri-capabilities",
      "tauri-mobile-targets",
      "tauri-sidecar",
      "tauri-advanced-updater",
      "multi-window-orchestration",
      "rust-audio-pipeline",
      "onnx-inference",
      "stronghold-secrets",
      "oauth-pkce-desktop",
      "deepgram-streaming-stt",
      "realtime-websocket-rust",
      "compliance-router",
      "animation-3d-layer",
      "document-ingestion"
    ],
    "requires": []
  },
  "contextEntry": "CONTEXT_SUMMARY.md",
  "context": {
    "entry": "CONTEXT_SUMMARY.md",
    "title": "Tauri Desktop Studio",
    "summary": "Production Tauri 2.x for desktop + mobile. Rust audio/ML, Next.js 15, animation/3D, real-time STT, ComplianceRouter, sidecars + advanced updater.",
    "tags": [
      "tauri",
      "rust",
      "nextjs",
      "desktop",
      "mobile",
      "audio-ml",
      "onnx",
      "deepgram",
      "ipc",
      "capabilities",
      "compliance"
    ],
    "bootstrapFiles": [
      "CONTEXT_SUMMARY.md"
    ],
    "maxTokens": 750,
    "excludeGlobs": [
      "**/node_modules/**",
      "**/dist/**",
      "**/build/**",
      "**/coverage/**",
      "**/target/**",
      "**/*.zip",
      "**/*.tar*"
    ],
    "lazyLoadSections": [
      "CLAUDE.md",
      "skills/*/SKILL.md",
      "commands/*.md",
      "agents/*.md"
    ]
  }
}
