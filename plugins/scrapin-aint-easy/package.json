{
  "name": "scrapin-aint-easy",
  "version": "1.0.0",
  "description": "Documentation intelligence engine, algorithm library, and codebase drift detection system for Claude Code",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "scrapin-aint-easy": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/cli.ts --mcp",
    "start": "node dist/cli.js --mcp",
    "start:lsp": "node dist/cli.js --lsp",
    "start:all": "node dist/cli.js --mcp --lsp --cron",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "ci": "pnpm run typecheck && pnpm run lint && pnpm run test",
    "cron:run": "node dist/cli.js --cron-only",
    "drift:agents": "node dist/cli.js --run-job agent-drift-scan",
    "drift:code": "node dist/cli.js --run-job code-drift-scan",
    "algo:index": "node dist/cli.js --run-job algo-sweep",
    "graph:stats": "node dist/cli.js --graph-stats"
  },
  "dependencies": {
    "@mendable/firecrawl-js": "^4.19.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@readme/openapi-parser": "^2.7.0",
    "@typescript-eslint/typescript-estree": "^8.59.0",
    "@xenova/transformers": "^2.17.2",
    "hnswlib-node": "^3.0.0",
    "ignore": "^5.3.2",
    "js-yaml": "^4.1.1",
    "kuzu": "^0.7.1",
    "node-cron": "^3.0.3",
    "node-fetch": "^3.3.2",
    "pino": "^9.14.0",
    "puppeteer": "^23.11.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.39",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^9.39.4",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
