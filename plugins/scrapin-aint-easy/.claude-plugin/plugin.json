{
  "$schema": "https://claude.local/schemas/plugin.schema.json",
  "name": "scrapin-aint-easy",
  "version": "1.0.0",
  "description": "Documentation intelligence engine, algorithm library, and codebase/agent drift detection system for Claude Code",
  "author": {
    "name": "Markus Ahling",
    "email": "Markus@thelobbi.io"
  },
  "license": "MIT",
  "homepage": "https://github.com/markus41/claude/tree/main/plugins/scrapin-aint-easy",
  "repository": "https://github.com/markus41/claude",
  "keywords": [
    "documentation",
    "algorithms",
    "drift-detection",
    "knowledge-graph",
    "mcp",
    "lsp",
    "interview-setup",
    "code-intelligence"
  ],
  "permissions": {
    "requires": [
      "read",
      "write",
      "bash"
    ],
    "optional": [
      "agent",
      "mcp",
      "network"
    ]
  },
  "capabilities": {
    "provides": [
      "documentation-intelligence",
      "algorithm-library",
      "codebase-drift-detection",
      "agent-drift-monitoring",
      "knowledge-graph",
      "interview-driven-setup",
      "mcp-server"
    ],
    "requires": []
  },
  "mcpServers": {
    "scrapin-aint-easy": {
      "command": "node",
      "args": [
        "${CLAUDE_PLUGIN_ROOT}/dist/cli.js",
        "--mcp"
      ]
    }
  },
  "context": {
    "title": "Scrapin' Ain't Easy",
    "summary": "Documentation intelligence engine: graph-crawl live API docs, search with vector + graph traversal, detect codebase/agent drift, look up algorithms from TheAlgorithms/NeetCode/Refactoring Guru, and run interview-first project setup. 7 commands, 5 skills, 12 agents, 1 MCP server with 17 tools.",
    "maxTokens": 400,
    "excludeGlobs": [
      "**/node_modules/**",
      "**/dist/**",
      "**/data/**",
      "**/coverage/**",
      "**/*.zip"
    ],
    "lazyLoadSections": [
      "CLAUDE.md",
      "commands/scrapin-setup.md",
      "commands/scrapin-search.md",
      "commands/scrapin-drift.md"
    ]
  },
  "commands": {
    "scrapin-algo": "commands/scrapin-algo.md",
    "scrapin-crawl": "commands/scrapin-crawl.md",
    "scrapin-diff": "commands/scrapin-diff.md",
    "scrapin-drift": "commands/scrapin-drift.md",
    "scrapin-search": "commands/scrapin-search.md",
    "scrapin-setup": "commands/scrapin-setup.md",
    "scrapin-status": "commands/scrapin-status.md"
  },
  "skills": {
    "bug-triage": "skills/bug-triage/SKILL.md",
    "code-review": "skills/code-review/SKILL.md",
    "migration-planner": "skills/migration-planner/SKILL.md",
    "project-setup": "skills/project-setup/SKILL.md",
    "release-notes": "skills/release-notes/SKILL.md"
  },
  "agents": {
    "agent-drift-detector": "agents/agent-drift-detector.md",
    "algo-indexer": "agents/algo-indexer.md",
    "backend-architect": "agents/backend-architect.md",
    "code-drift-detector": "agents/code-drift-detector.md",
    "doc-crawler": "agents/doc-crawler.md",
    "doc-cron-runner": "agents/doc-cron-runner.md",
    "doc-diff-watcher": "agents/doc-diff-watcher.md",
    "doc-graph-builder": "agents/doc-graph-builder.md",
    "doc-lsp-resolver": "agents/doc-lsp-resolver.md",
    "frontend-specialist": "agents/frontend-specialist.md",
    "infra-guardian": "agents/infra-guardian.md",
    "qa-analyst": "agents/qa-analyst.md"
  },
  "categories": [
    "documentation",
    "agents",
    "utilities"
  ],
  "provides": {
    "commands": 7,
    "agents": 12,
    "skills": 5
  }
}