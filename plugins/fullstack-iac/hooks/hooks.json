{
  "$schema": "../../../schemas/hooks.schema.json",
  "version": "2.0.0",
  "plugin": "fullstack-iac",
  "description": "",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Validate file syntax and lint before writing (Python/TS/Terraform/K8s/Docker/SQL)'",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Provide next steps after scaffolding (FastAPI/React/fullstack/K8s/Terraform/CI/deploy/audit/database)'",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "settings": {}
}
