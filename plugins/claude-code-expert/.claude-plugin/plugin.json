      "expert",
      "orchestration",
      "reasoning",
      "debugging",
      "mcp",
      "skills",
      "agents",
      "ci-cd",
      "enterprise",
      "tutorials"
    ],
    "bootstrapFiles": [
      "CONTEXT_SUMMARY.md"
    ],
    "maxTokens": 700,
    "excludeGlobs": [
      "**/node_modules/**",
      "**/dist/**",
      "**/build/**",
      "**/coverage/**",
      "**/*.zip",
      "**/*.tar*"
