{
  "name": "project-management-plugin",
  "version": "1.3.0",
  "description": "Universal project manager with keep-Claude-on-task guardrails: focus anchor, scope lock, done-when contract, over-engineering detector, drift auditor, turn budget, user-prompt archive, and compaction-safe handoff. Plus interview-first init, micro-task decomposition, deep research, transactional state MCP, and 9 PM platform integrations.",
  "author": {
    "name": "Markus Ahling",
    "email": "Markus@thelobbi.io"
  },
  "license": "MIT",
  "repository": "https://github.com/markus41/claude",
  "keywords": [
    "project-management",
    "task-decomposition",
    "research-first",
    "micro-tasks",
    "autonomous",
    "pm-integration",
    "mcp"
  ],
  "dependencies": [],
  "userConfig": {
    "github_token": {
      "description": "GitHub personal access token (for GitHub Projects sync)",
      "sensitive": true
    },
    "linear_api_key": {
      "description": "Linear API key (for Linear sync)",
      "sensitive": true
    },
    "notion_token": {
      "description": "Notion integration token (for Notion sync)",
      "sensitive": true
    },
    "asana_token": {
      "description": "Asana personal access token (for Asana sync)",
      "sensitive": true
    },
    "trello_api_key": {
      "description": "Trello API key (for Trello sync)",
      "sensitive": true
    },
    "trello_token": {
      "description": "Trello token (for Trello sync)",
      "sensitive": true
    },
    "clickup_token": {
      "description": "ClickUp API token (for ClickUp sync)",
      "sensitive": true
    },
    "monday_api_key": {
      "description": "Monday.com API key (for Monday sync)",
      "sensitive": true
    },
    "todoist_token": {
      "description": "Todoist API token (for Todoist sync)",
      "sensitive": true
    }
  },
  "categories": [
    "project-management",
    "orchestration",
    "agents"
  ],
  "mcpServers": {
    "pm-mcp": {
      "command": "node",
      "args": [
        "${CLAUDE_PLUGIN_ROOT}/mcp/pm-server.mjs"
      ],
      "env": {
        "CLAUDE_PROJECT_DIR": "${CLAUDE_PROJECT_DIR}"
      }
    }
  }
}
