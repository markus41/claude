{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/markus41/claude/plugins/project-management-plugin/schemas/project.schema.json",
  "title": "Project",
  "description": "Schema for a project-management-plugin project state file",
  "type": "object",
  "required": [
    "id",
    "name",
    "goal",
    "type",
    "status",
    "phases",
    "created_at",
    "updated_at",
    "metadata"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique project identifier (lowercase alphanumeric and hyphens)",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string",
      "description": "Human-readable project name",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "description": "One-sentence statement of what this project must achieve",
      "minLength": 10
    },
    "type": {
      "type": "string",
      "description": "Broad project category used to select default templates and research strategies",
      "enum": [
        "software",
        "content",
        "research",
        "business"
      ]
    },
    "status": {
      "type": "string",
      "description": "Lifecycle state of the project",
      "enum": [
        "INITIALIZING",
        "READY",
        "IN_PROGRESS",
        "PAUSED",
        "COMPLETE",
        "CANCELLED"
      ]
    },
    "phases": {
      "type": "array",
      "description": "Ordered list of project phases",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "status",
          "task_ids"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "description": "Phase identifier (e.g. 'phase-1')",
            "pattern": "^[a-z0-9-]+$"
          },
          "name": {
            "type": "string",
            "description": "Display name of the phase"
          },
          "description": {
            "type": "string",
            "description": "What this phase accomplishes"
          },
          "status": {
            "type": "string",
            "enum": [
              "PENDING",
              "IN_PROGRESS",
              "COMPLETE",
              "SKIPPED"
            ]
          },
          "task_ids": {
            "type": "array",
            "description": "Ordered list of task IDs that belong to this phase",
            "items": {
              "type": "string",
              "pattern": "^T-[0-9]+$"
            }
          }
        }
      }
    },
    "pm_integration": {
      "type": [
        "object",
        "null"
      ],
      "description": "Connected project management platform details",
      "required": [
        "platform"
      ],
      "additionalProperties": false,
      "properties": {
        "platform": {
          "type": "string",
          "description": "The PM platform this project is synced with",
          "enum": [
            "github",
            "linear",
            "notion",
            "asana",
            "trello",
            "clickup",
            "monday",
            "todoist",
            "local"
          ]
        },
        "external_project_id": {
          "type": [
            "string",
            "null"
          ],
          "description": "The ID of the corresponding project/board/space in the external platform"
        },
        "last_sync_at": {
          "type": [
            "string",
            "null"
          ],
          "description": "ISO 8601 timestamp of the most recent successful sync",
          "format": "date-time"
        }
      }
    },
    "created_at": {
      "type": "string",
      "description": "ISO 8601 timestamp when the project was created",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "description": "ISO 8601 timestamp when the project was last modified",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "description": "Runtime and configuration metadata for the project",
      "additionalProperties": false,
      "properties": {
        "depth_preset": {
          "type": "string",
          "description": "Decomposition depth preset selected during initialization",
          "enum": [
            "shallow",
            "standard",
            "deep",
            "exhaustive"
          ]
        },
        "loop_count": {
          "type": "integer",
          "description": "Number of autonomous loop iterations completed",
          "minimum": 0
        },
        "last_checkpoint": {
          "type": [
            "string",
            "null"
          ],
          "description": "Relative path to the most recent checkpoint file within the project state directory"
        }
      }
    }
  }
}
