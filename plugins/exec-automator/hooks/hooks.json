{
  "$schema": "../../../schemas/hooks.schema.json",
  "version": "2.0.0",
  "plugin": "exec-automator",
  "description": "Hook definitions for executive director automation workflow tracking and state management",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/workflow-init.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/document-detect.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/execution-tracker.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/workflow-cleanup.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "settings": {
    "state_dir": "${CLAUDE_PLUGIN_ROOT}/state",
    "checkpoint_dir": "${OBSIDIAN_VAULT_PATH}/Projects/exec-automator/checkpoints",
    "analysis_archive_dir": "${OBSIDIAN_VAULT_PATH}/Projects/exec-automator/analyses",
    "log_level": "INFO",
    "max_session_duration_hours": 8,
    "auto_checkpoint_interval_minutes": 30
  },
  "metadata": {
    "author": "Brookside BI",
    "license": "Proprietary",
    "created": "2025-12-17",
    "updated": "2025-12-17"
  }
}
