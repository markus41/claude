{
  "$schema": "https://claude.local/schemas/plugin.schema.json",
  "name": "linear-orchestrator",
  "version": "1.0.0",
  "description": "Advanced Linear integration with two-way sync to Harness Code and Microsoft Planner. Covers Linear GraphQL API, OAuth 2.0, webhooks, attachments, agents (AIG), MCP, cycles, projects, initiatives, customer requests, SLA, triage, templates, sub-issues, and diffs. 22 commands, 10 skills, 12 agents.",
  "author": {
    "name": "Markus Ahling",
    "email": "markus@lobbi.io"
  },
  "license": "MIT",
  "repository": "https://github.com/markus41/claude",
  "keywords": [
    "linear",
    "linear-app",
    "graphql",
    "oauth",
    "webhooks",
    "agents",
    "aig",
    "harness",
    "harness-code",
    "microsoft-planner",
    "ms-graph",
    "two-way-sync",
    "mcp",
    "cycles",
    "projects",
    "initiatives",
    "customer-requests",
    "sla",
    "triage",
    "issue-tracking",
    "orchestration",
    "automation",
    "agent-signals"
  ],
  "permissions": {
    "requires": [
      "network:linear.app",
      "network:api.linear.app",
      "secrets:LINEAR_API_KEY",
      "secrets:LINEAR_OAUTH_CLIENT_SECRET",
      "secrets:LINEAR_WEBHOOK_SECRET"
    ],
    "optional": [
      "network:app.harness.io",
      "secrets:HARNESS_API_TOKEN",
      "secrets:HARNESS_ACCOUNT_ID",
      "network:graph.microsoft.com",
      "secrets:GRAPH_CLIENT_SECRET",
      "secrets:GRAPH_TENANT_ID"
    ]
  },
  "capabilities": {
    "provides": [
      "linear.issue.crud",
      "linear.cycle.management",
      "linear.project.management",
      "linear.initiative.management",
      "linear.customer.requests",
      "linear.sla.tracking",
      "linear.triage.workflow",
      "linear.webhook.handler",
      "linear.attachment.upload",
      "linear.agent.signals",
      "linear.mcp.bridge",
      "harness.code.sync",
      "msplanner.sync"
    ],
    "requires": []
  },
  "context": {
    "entry": "CONTEXT_SUMMARY.md",
    "title": "Linear Orchestrator",
    "summary": "Advanced Linear integration with bidirectional Harness Code + Microsoft Planner sync. 22 commands, 10 skills, 12 agents covering GraphQL, OAuth, webhooks, agents/AIG, cycles, projects, initiatives, customer requests, SLA, triage, templates, and migration.",
    "tags": [
      "linear",
      "graphql",
      "oauth",
      "webhooks",
      "agents",
      "harness",
      "microsoft-planner",
      "two-way-sync",
      "mcp"
    ],
    "bootstrapFiles": [
      "CONTEXT_SUMMARY.md"
    ],
    "maxTokens": 800,
    "excludeGlobs": [
      "**/node_modules/**",
      "**/dist/**",
      "**/build/**",
      "**/coverage/**",
      "**/*.zip",
      "**/*.tar*"
    ],
    "lazyLoadSections": [
      "CLAUDE.md",
      "README.md",
      "skills/*/SKILL.md",
      "commands/*.md",
      "agents/*.md",
      "lib/**/*.ts",
      "docs/*.md"
    ]
  },
  "contextEntry": "CONTEXT_SUMMARY.md"
}
